# App identity
APP_APP_NAME=Whisper Chat Transcriber

# Data storage
APP_DATA_DIR=data

# Default Whisper runtime
APP_WHISPER_MODEL_SIZE=small
APP_WHISPER_DEVICE=cpu
APP_WHISPER_COMPUTE_TYPE=int8

# Transcription pipeline
APP_TRANSCRIPTION_WORKERS=2
APP_TRANSCRIPTION_PROJECT_CONCURRENCY=1
APP_TRANSCRIPTION_CHUNK_SECONDS=45
APP_TRANSCRIPTION_ENABLE_SILENCE_TRIM=true
APP_TRANSCRIPTION_CACHE_ENABLED=true
